# Keycloak server URL (no trailing slash, no /auth path).
# KC v17+ dropped the /auth/ prefix by default. Set KEYCLOAK_BASE_PATH=/auth only if your KC
# is configured with --http-relative-path=/auth (legacy compat).
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_BASE_PATH=

# Realm in which the service-account client lives.
KEYCLOAK_REALM=master

# Auth: client_credentials (recommended for service accounts) — ignores USERNAME/PASSWORD.
KEYCLOAK_CLIENT_ID=litellm-mcp-svc
KEYCLOAK_CLIENT_SECRET=

# Auth: legacy password grant (admin-cli) — leave CLIENT_SECRET unset to use this path.
# KEYCLOAK_USERNAME=
# KEYCLOAK_PASSWORD=

# MCP transport: streamable-http (default for the wrapper) or stdio.
TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Bearer token enforced on HTTP transports. Recommended whenever the wrapper exposes write
# authority and is reachable from anywhere other than localhost.
MCP_BEARER_TOKEN=

# Optional: log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
